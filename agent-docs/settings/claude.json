{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "cleanupPeriodDays": 30,
  "effortLevel": "xhigh",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_ENHANCED_TELEMETRY_BETA": "1",
    "OTEL_EXPORTER_OTLP_TRACES_ENDPOINT": "http://127.0.0.1:58473/v1/traces",
    "OTEL_EXPORTER_OTLP_TRACES_PROTOCOL": "http/json",
    "OTEL_LOGS_EXPORTER": "none",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_METRICS_EXPORTER": "none",
    "OTEL_TRACES_EXPORTER": "otlp"
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754425548865
  },
  "includeCoAuthoredBy": true,
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(gh pr:*)",
      "Bash(go:*)",
      "Bash(go list:*)",
      "Bash(go mod:*)",
      "Bash(go run:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(go doc:*)",
      "Bash(task:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(touch:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(test:*)",
      "Bash(shellcheck:*)",
      "Fetch(https://github.com/)",
      "Fetch(https://raw.githubusercontent.com/)",
      "Fetch(domain:docs.anthropic.com)",
      "Fetch(domain:github.com)",
      "Fetch(domain:stackoverflow.com)",
      "Fetch(domain:nodejs.org)",
      "Fetch(domain:go.dev)",
      "Fetch(domain:ziglang.org)",
      "Web Search(*)"
    ],
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(terraform state mv:*)",
      "Bash(terraform state rm:*)"
    ]
  },
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "enabled": false
  },
  "skipDangerousModePermissionPrompt": true
}
