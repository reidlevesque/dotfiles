Include ~/.ssh/config.d/*.conf
Include /Users/rlevesque/.colima/ssh_config

Host omni-rlevesque
  HostName nvdigd0tp9pri59
  User rlevesque
  ProxyCommand /usr/local/bin/tsh proxy ssh %r@%h

Host devcontainer
  HostName 127.0.0.1
  User vscode
  Port 23348
  HostKeyAlias devcontainer

Host *
  Compression yes
  AddKeysToAgent no
  ForwardAgent no
  ServerAliveInterval 60
  ServerAliveCountMax 120
  TCPKeepAlive yes
  # Use connection multiplexing to reuse existing connections
  ControlMaster auto
  ControlPath ~/.ssh/sockets/%r@%h-%p
  ControlPersist 600
#   StrictHostKeyChecking=accept-new
